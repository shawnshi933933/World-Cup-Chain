# ============================================================
# 环境变量配置文件
# 使用方法：
#   cp deploy/.env.template .env
#   然后编辑 .env，填入真实的值
# ============================================================

# PostgreSQL 数据库地址（使用上面脚本创建的数据库，无需修改）
DATABASE_URL=postgresql://worldcup:wc2026db@localhost:5432/worldcup

# 网站访问密码（和 Replit 上设置的 APP_PASSWORD 保持一致）
APP_PASSWORD=在这里填入你的密码

# 运行环境（不要修改）
NODE_ENV=production

# API 服务器端口（不要修改，nginx 会代理这个端口）
PORT=3001

# ============================================================
# Polymarket API 凭证（可选，也可以在网站设置页面填写）
# ============================================================
# POLYMARKET_API_KEY=
# POLYMARKET_SECRET=
# POLYMARKET_PASSPHRASE=
# POLYMARKET_WALLET=
